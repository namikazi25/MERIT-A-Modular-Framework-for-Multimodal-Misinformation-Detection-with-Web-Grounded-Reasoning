# Copy this file to `.env` and fill in your keys.
# The app loads this via python-dotenv at startup (see main.py).

# --- Provider API keys ---
# For OpenAI models (e.g., gpt-4o)
OPENAI_API_KEY=sk-your-openai-key

# For Google Gemini models (e.g., gemini-2.5-flash)
GOOGLE_API_KEY=your-google-api-key

# For DeepInfra (OpenAI-compatible) models (e.g., google/gemma-3-27b-it)
DEEPINFRA_API_KEY=your-deepinfra-api-key

# --- Single provider switch (only indicator) ---
# Set the provider used everywhere: openai | google | deepinfra
# This is the only setting that controls provider selection.
ALIGN_PROVIDER=openai

# Model name (leave empty to use provider default)
# Examples: gpt-4o, gpt-4o-mini, gemini-2.5-flash, google/gemma-3-27b-it
ALIGN_MODEL=

# Temperature for LLM responses (0.0 - 1.0)
ALIGN_TEMPERATURE=0.2

# Limit how many dataset samples go through the relevancy checker
# when you do not pass --image/--headline on the CLI.
# Set to 1 to only check the first sample, or a higher number.
RELEVANCY_MAX_CHECKS=1

# How many dataset samples to run through the entire pipeline
# (relevancy, visual veracity, question/answering if enabled, selection, judgement)
# when --image/--headline are not provided on the CLI.
# This is the primary control for sample count.
PIPELINE_MAX_SAMPLES=1

# Web search provider for question answering: brave | duckduckgo
SEARCH_PROVIDER=brave

# Brave Search API key (required when SEARCH_PROVIDER=brave)
BRAVE_API_KEY=brave-api-key-here

# Optional: tune minimum delay between outbound search requests (seconds)
# BRAVE_SEARCH_MIN_INTERVAL=1.0
# DUCKDUCKGO_SEARCH_MIN_INTERVAL=1.5

# Enable answering generated questions via Brave search + LLM (0/1)
ANSWER_ENABLE=0
# Max number of sources to feed LLM per question
ANSWER_MAX_SOURCES=5

# Emit consolidated JSON output per sample for downstream LLM steps (0/1)
EMIT_FINAL_JSON=1

# If set, append each final per-sample JSON object to this JSONL file
# for later evaluation with scripts/evaluate.py
PIPELINE_OUTPUT_JSONL=

# Optional: HTML report written after each run (per-batch sample set)
PIPELINE_HTML_REPORT=
PIPELINE_HTML_TITLE=Pipeline Results
# If 1, embed images as base64 data URLs for a self-contained HTML report
PIPELINE_HTML_INLINE_IMAGES=0

# Checkpointing configuration
PIPELINE_CHECKPOINT_DIR=
PIPELINE_CHECKPOINT_SIZE=100
PIPELINE_RESUME=
